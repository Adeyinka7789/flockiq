SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=postgresql://flockiq_app:flockiq_dev_pass@localhost:5432/flockiq_dev
REDIS_URL=redis://127.0.0.1:6379/1
# Dedicated session store (production cached_db backend). Local dev uses the db
# backend and ignores this. Production defaults to DB 2 of REDIS_URL if unset.
REDIS_SESSION_URL=redis://127.0.0.1:6379/2
# Celery — broker on DB 0, results on DB 3. NEVER point the broker at DB 1
# (cache) or DB 2 (sessions): a broker flush would wipe them. See RUNBOOK.md.
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/3
TERMII_API_KEY=
TERMII_SENDER_ID=FlockIQ
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
OPENWEATHERMAP_API_KEY=
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=FlockIQ <noreply@flockiq.com>
ADMIN_EMAIL=your-admin@email.com
SITE_URL=http://localhost:8000
